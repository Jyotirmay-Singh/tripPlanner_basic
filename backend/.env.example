# Example backend environment. Copy to backend/.env for local dev, or mirror these keys into the
# host dashboard (Render Environment tab) for production. NEVER commit real secrets — only this
# placeholder file is git-tracked (see .gitignore: !.env.example).

# --- Required (the app will not boot if these three are missing) ---
MONGO_URL=mongodb+srv://<user>:<urlencoded-password>@<cluster>.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=tripsplitter
JWT_SECRET=<long-random-string>

# --- Seed admin (created on first startup if it does not exist; ADMIN_EMAIL must be @gmail.com) ---
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=<password>
ADMIN_PIN=1234

# --- Email (Resend). Powers forgot-PIN AND the Phase 9 verify-email / reset-password links.
#     If RESEND_API_KEY is unset the link/token is logged instead of sent.
#     APP_URL is the base for every emailed link — set it to the hosted WEB url in production
#     (e.g. https://tripsplitter-web.vercel.app) so /verify-email?token= / /reset-password?token=
#     deep-link into the app; when blank, the bare token is logged/emailed instead. ---
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev
APP_URL=

# --- Email features master switch (Phase 9: verify-email + forgot-PASSWORD). Default: true.
#     Set to false to "ghost" these flows until a DELIVERABLE sender domain exists (a free/
#     blocklisted domain such as *.dpdns.org is rejected by Gmail, so nothing arrives). When false:
#     new signups are auto-verified (no verify banner), NO verification/reset emails are sent (so
#     nothing bounces), and the app hides the banner + "Forgot password?" link (via /api/meta/config).
#     PIN recovery (/auth/reset-pin-by-password) and in-app change-password still work.
#     Re-enable by setting true (or removing this) and redeploying — no frontend rebuild needed. ---
EMAIL_FEATURES_ENABLED=true

# --- Google Sign-In: one client id, or a comma-separated list of accepted audiences ---
GOOGLE_CLIENT_ID=<web-client-id>,<ios-client-id>,<android-client-id>
