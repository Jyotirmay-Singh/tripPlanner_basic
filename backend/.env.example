# Example backend environment. Copy to backend/.env for local dev, or mirror these keys into the
# host dashboard (Render Environment tab) for production. NEVER commit real secrets — only this
# placeholder file is git-tracked (see .gitignore: !.env.example).

# --- Required (the app will not boot if these three are missing) ---
MONGO_URL=mongodb+srv://<user>:<urlencoded-password>@<cluster>.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=tripsplitter
JWT_SECRET=<long-random-string>

# --- Seed admin (created on first startup if it does not exist; ADMIN_EMAIL must be @gmail.com) ---
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=<password>
ADMIN_PIN=1234

# --- Email (forgot-PIN via Resend; if RESEND_API_KEY is unset the reset token is logged instead) ---
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev
APP_URL=

# --- Google Sign-In: one client id, or a comma-separated list of accepted audiences ---
GOOGLE_CLIENT_ID=<web-client-id>,<ios-client-id>,<android-client-id>
