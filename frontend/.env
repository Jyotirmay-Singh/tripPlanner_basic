EXPO_PUBLIC_BACKEND_URL=http://localhost:8000
EXPO_USE_FAST_RESOLVER="1"
# --- Google OAuth client IDs (Google Cloud Console > APIs & Services > Credentials) ---
# Format for every value: <numbers>-<hash>.apps.googleusercontent.com
# Web client ID (type "Web application"). Also used as the audience your backend verifies.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="307368957277-58jdf9opq70e195gm5n1pcf4ucfd7rlt.apps.googleusercontent.com"
# iOS client ID (type "iOS"), tied to your iOS bundle identifier.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="307368957277-19ho7nrl2drsdvkahh7nkqpi6f2tag9h.apps.googleusercontent.com"
# Android client ID (type "Android"), tied to android.package + SHA-1 fingerprint.
# >>> PASTE YOUR ANDROID CLIENT ID HERE <<< — leaving this empty causes:
# "Client Id property 'androidClientId' must be defined to use Google auth on this platform"
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID="307368957277-cc4k3o7or765v1g6tfi767stk23296nk.apps.googleusercontent.com"
